{
  "__inputs": [
    {
      "name": "DS_STOCKPULSE",
      "label": "StockPulse Redshift",
      "description": "Amazon Redshift Serverless — stockpulse-wg",
      "type": "datasource",
      "pluginId": "grafana-redshift-datasource",
      "pluginName": "Amazon Redshift"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "grafana-redshift-datasource",
      "name": "Amazon Redshift",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "barchart",
      "name": "Bar chart",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    },
    {
      "type": "panel",
      "id": "gauge",
      "name": "Gauge",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "StockPulse — Real-Time Stock Market Data Pipeline on AWS",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Close Price — All Symbols",
      "type": "barchart",
      "description": "Latest close price for all tracked symbols",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-redshift-datasource", "uid": "${DS_STOCKPULSE}" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "custom": { "fillOpacity": 80 }
        },
        "overrides": []
      },
      "options": {
        "orientation": "auto",
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" },
        "xField": "symbol"
      },
      "targets": [
        {
          "datasource": { "type": "grafana-redshift-datasource", "uid": "${DS_STOCKPULSE}" },
          "rawSQL": "SELECT symbol, CAST(\"close\" AS FLOAT) AS close FROM public.ohlcv WHERE trade_date = (SELECT MAX(trade_date) FROM public.ohlcv) ORDER BY close DESC",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Volume by Symbol",
      "type": "barchart",
      "description": "Total trading volume per symbol",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "grafana-redshift-datasource", "uid": "${DS_STOCKPULSE}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 80 }
        },
        "overrides": []
      },
      "options": {
        "orientation": "auto",
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "grafana-redshift-datasource", "uid": "${DS_STOCKPULSE}" },
          "rawSQL": "SELECT symbol, SUM(volume) AS total_volume FROM public.ohlcv WHERE trade_date = (SELECT MAX(trade_date) FROM public.ohlcv) GROUP BY symbol ORDER BY total_volume DESC",
          "format": "table",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "title": "Top Movers Today",
      "type": "table",
      "description": "Symbols ranked by price change % (most volatile first)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "grafana-redshift-datasource", "uid": "${DS_STOCKPULSE}" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "price_change_pct" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 2 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "yellow", "value": -1 },
                    { "color": "green", "value": 0 }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "close" },
            "properties": [
              { "id": "unit", "value": "currencyUSD" },
              { "id": "decimals", "value": 2 }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "price_change_pct", "desc": true }]
      },
      "targets": [
        {
          "datasource": { "type": "grafana-redshift-datasource", "uid": "${DS_STOCKPULSE}" },
          "rawSQL": "SELECT symbol, CAST(\"close\" AS FLOAT) AS close, CAST(price_change_pct AS FLOAT) AS price_change_pct, SUM(volume) AS total_volume FROM public.ohlcv WHERE trade_date = (SELECT MAX(trade_date) FROM public.ohlcv) GROUP BY symbol, \"close\", price_change_pct ORDER BY price_change_pct DESC",
          "format": "table",
          "refId": "C"
        }
      ]
    },
    {
      "id": 4,
      "title": "Pipeline Latency (ms)",
      "type": "gauge",
      "description": "Avg time from market bar timestamp to ingestion (ms). Target: < 90,000 ms",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 17 },
      "datasource": { "type": "grafana-redshift-datasource", "uid": "${DS_STOCKPULSE}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "max": 120000,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60000 },
              { "color": "red", "value": 90000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": { "type": "grafana-redshift-datasource", "uid": "${DS_STOCKPULSE}" },
          "rawSQL": "SELECT AVG(ingestion_time - timestamp_ms) AS avg_latency_ms FROM public.ohlcv WHERE trade_date = (SELECT MAX(trade_date) FROM public.ohlcv)",
          "format": "table",
          "refId": "D"
        }
      ]
    },
    {
      "id": 5,
      "title": "Records Ingested Today",
      "type": "stat",
      "description": "Total OHLCV bars loaded into Redshift for the latest trade date",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 17 },
      "datasource": { "type": "grafana-redshift-datasource", "uid": "${DS_STOCKPULSE}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "green", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "datasource": { "type": "grafana-redshift-datasource", "uid": "${DS_STOCKPULSE}" },
          "rawSQL": "SELECT COUNT(*) AS record_count FROM public.ohlcv WHERE trade_date = (SELECT MAX(trade_date) FROM public.ohlcv)",
          "format": "table",
          "refId": "E"
        }
      ]
    },
    {
      "id": 6,
      "title": "OHLC — ${symbol}",
      "type": "table",
      "description": "Open / High / Low / Close for selected symbol",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 17 },
      "datasource": { "type": "grafana-redshift-datasource", "uid": "${DS_STOCKPULSE}" },
      "fieldConfig": {
        "defaults": { "decimals": 2 },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "open" },
            "properties": [{ "id": "unit", "value": "currencyUSD" }]
          },
          {
            "matcher": { "id": "byName", "options": "high" },
            "properties": [
              { "id": "unit", "value": "currencyUSD" },
              { "id": "custom.displayMode", "value": "color-text" },
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "low" },
            "properties": [
              { "id": "unit", "value": "currencyUSD" },
              { "id": "custom.displayMode", "value": "color-text" },
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "close" },
            "properties": [{ "id": "unit", "value": "currencyUSD" }]
          }
        ]
      },
      "options": { "showHeader": true },
      "targets": [
        {
          "datasource": { "type": "grafana-redshift-datasource", "uid": "${DS_STOCKPULSE}" },
          "rawSQL": "SELECT trade_date, CAST(\"open\" AS FLOAT) AS \"open\", CAST(high AS FLOAT) AS high, CAST(low AS FLOAT) AS low, CAST(\"close\" AS FLOAT) AS \"close\", volume FROM public.ohlcv WHERE symbol = '$symbol' ORDER BY trade_date DESC LIMIT 30",
          "format": "table",
          "refId": "F"
        }
      ]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 38,
  "tags": ["stockpulse", "aws", "data-engineering", "stocks"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "AAPL", "value": "AAPL" },
        "hide": 0,
        "includeAll": false,
        "label": "Symbol",
        "multi": false,
        "name": "symbol",
        "options": [
          { "selected": true,  "text": "AAPL",  "value": "AAPL" },
          { "selected": false, "text": "MSFT",  "value": "MSFT" },
          { "selected": false, "text": "GOOGL", "value": "GOOGL" },
          { "selected": false, "text": "AMZN",  "value": "AMZN" },
          { "selected": false, "text": "TSLA",  "value": "TSLA" },
          { "selected": false, "text": "META",  "value": "META" },
          { "selected": false, "text": "NVDA",  "value": "NVDA" },
          { "selected": false, "text": "JPM",   "value": "JPM"  },
          { "selected": false, "text": "V",     "value": "V"    },
          { "selected": false, "text": "JNJ",   "value": "JNJ"  }
        ],
        "query": "",
        "type": "custom"
      }
    ]
  },
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "timezone": "America/New_York",
  "title": "StockPulse — Live Market Data",
  "uid": "stockpulse-main",
  "version": 1
}
