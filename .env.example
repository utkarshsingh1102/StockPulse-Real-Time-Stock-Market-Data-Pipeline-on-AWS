# =============================================================================
# StockPulse — Configuration Template
# Copy this file to .env and fill in your actual values.
#   cp .env.example .env
# .env is gitignored and will never be committed.
# =============================================================================

# AWS
AWS_REGION=us-east-1

# S3 Buckets (must be globally unique — change if name is taken)
S3_BUCKET=stockpulse-data-us
S3_SCRIPTS_BUCKET=stockpulse-scripts-us

# Kinesis
KINESIS_STREAM=stockpulse-stream

# SQS
DLQ_NAME=stockpulse-dlq

# SNS
SNS_TOPIC_NAME=stockpulse-alerts

# Glue
GLUE_DB=stockpulse_db
GLUE_JOB_NAME=stockpulse-ohlcv-transform

# Lambda
LAMBDA_INGESTER_NAME=stockpulse-ingester
LAMBDA_PROCESSOR_NAME=stockpulse-processor

# Polygon.io API key is stored in AWS Secrets Manager — not here.
# Store it once: aws secretsmanager create-secret \
#   --name stockpulse/polygon-api-key \
#   --secret-string '{"POLYGON_API_KEY":"your_key_here"}'
# Then set the secret name below (this is safe to commit).
POLYGON_SECRET_NAME=stockpulse/polygon-api-key

# Tracked symbols (comma-separated, no spaces)
SYMBOLS=AAPL,MSFT,GOOGL,AMZN,TSLA,META,NVDA,JPM,V,JNJ
